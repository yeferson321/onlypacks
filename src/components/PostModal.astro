---
interface Props {
  stories: string[];
}
const { stories } = Astro.props;
---

<div class="relative w-full h-145 overflow-hidden rounded-b-4xl">
  <div id="profile-carousel" aria-label="Carousel de historias">
    {[...stories, stories[0]].map((src, index) => (
      <div class="carousel-item" data-carousel-item>
        <img
          src={src}
          width="104"
          height="580"
          loading={index === 0 ? "eager" : "lazy"}
          fetchpriority={index === 0 ? "high" : "low"}
          decoding={index === 0 ? "auto" : "async"}
          crossorigin="anonymous"
          class="w-full h-full object-cover object-[50%_10%]"
          alt={`Historia ${index === stories.length ? 1 : index + 1}`}
        />
        <div class="overlay pointer-events-none absolute inset-0"></div>
      </div>
    ))}
  </div>
</div>

<script>
import { limitExecution } from '@/utils/limitExecution';
import { getAverageColor } from '@/utils/getAverageColor';

const carousel = document.getElementById("profile-carousel")!;
const items = carousel.querySelectorAll<HTMLElement>("[data-carousel-item]");
const indicators = document.querySelectorAll<HTMLButtonElement>("[data-carousel-indicator]");

const TOTAL = items.length - 1; // Last item is clone
const AUTO_SCROLL_MS = 2000;

let width = carousel.parentElement!.offsetWidth;
let index = 0;
let startX = 0;
let timer: ReturnType<typeof setInterval>;

// Apply color overlays after images decode
items.forEach(async (item) => {
  const img = item.querySelector("img")!;
  const overlay = item.querySelector<HTMLDivElement>(".overlay")!;
  await img.decode();
  const { r, g, b } = getAverageColor(img);
  overlay.style.background = `
    linear-gradient(to bottom, rgba(0,0,0,0.5), transparent 20%),
    linear-gradient(to top, rgba(${r},${g},${b},0.9), transparent 50%)
  `;
});

const moveTo = (i: number, animate = true) => {
  carousel.classList.toggle("no-transition", !animate);
  carousel.style.transform = `translateX(-${i * width}px)`;
  const realIndex = i === TOTAL ? 0 : i;
  indicators.forEach((btn, j) =>
    btn.setAttribute("aria-current", j === realIndex ? "true" : "false")
  );
};

// Infinite loop: jump silently from clone back to original
carousel.addEventListener("transitionend", () => {
  if (index === TOTAL) { index = 0; moveTo(0, false); }
});

// Auto-scroll
const startAuto = () => {
  timer = setInterval(() => {
    moveTo(++index);
    if (index === TOTAL) clearInterval(timer);
  }, AUTO_SCROLL_MS);
};
startAuto();

const navigate = (delta: number) => {
  clearInterval(timer);
  index = Math.max(0, index + delta);
  moveTo(index);
};

// Indicators
indicators.forEach((btn) =>
  btn.addEventListener("click", () => {
    clearInterval(timer);
    index = Number(btn.dataset.carouselIndicator);
    moveTo(index);
  })
);

// Touch
carousel.addEventListener("touchstart", (e) => (startX = e.touches[0].clientX), { passive: true });
carousel.addEventListener("touchend", (e) => {
  const delta = startX - e.changedTouches[0].clientX;
  if (Math.abs(delta) >= 50) navigate(delta > 0 ? 1 : -1);
});

// Mouse wheel (horizontal)
carousel.addEventListener("wheel", limitExecution((e: WheelEvent) => {
  if (Math.abs(e.deltaX) < Math.abs(e.deltaY) || Math.abs(e.deltaX) < 50) return;
  e.preventDefault();
  navigate(e.deltaX > 0 ? 1 : -1);
}, 300), { passive: false });

// Resize
window.addEventListener("resize", limitExecution(() => {
  width = carousel.parentElement!.offsetWidth;
  moveTo(index, false);
}, 100));
</script>

<style>
#profile-carousel {
  display: flex;
  height: 100%;
  transition: transform var(--transition-duration) var(--transition-timing);
  will-change: transform;
}
#profile-carousel.no-transition { transition: none; }
.carousel-item { position: relative; width: 100%; height: 100%; flex-shrink: 0; }
</style>

